<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>陪標管理系統</title>
<style>
  :root {
    --bg: #f5f4f0;
    --surface: #ffffff;
    --surface2: #f0ede8;
    --border: rgba(0,0,0,0.10);
    --border-md: rgba(0,0,0,0.18);
    --text: #1a1a18;
    --text2: #6b6a66;
    --text3: #9e9d99;
    --green-bg: #eaf3de;
    --green: #3b6d11;
    --amber-bg: #faeeda;
    --amber: #854f0b;
    --radius: 10px;
    --radius-lg: 14px;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: -apple-system, 'PingFang TC', 'Microsoft JhengHei', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; }

  /* Top bar */
  .topbar { background: var(--surface); border-bottom: 0.5px solid var(--border); padding: 0 1.5rem; display: flex; align-items: center; gap: 12px; height: 54px; position: sticky; top: 0; z-index: 100; }
  .topbar-logo { font-size: 15px; font-weight: 600; letter-spacing: -0.01em; }
  .topbar-sub { font-size: 12px; color: var(--text3); }
  .topbar-right { margin-left: auto; display: flex; align-items: center; gap: 10px; }
  .refresh-btn { background: none; border: 0.5px solid var(--border-md); border-radius: 8px; padding: 5px 12px; font-size: 12px; color: var(--text2); cursor: pointer; display: flex; align-items: center; gap: 5px; font-family: inherit; transition: background 0.15s; }
  .refresh-btn:hover { background: var(--surface2); }
  .refresh-btn svg { width: 13px; height: 13px; }
  .last-updated { font-size: 11px; color: var(--text3); }

  /* Layout */
  .container { max-width: 820px; margin: 0 auto; padding: 1.5rem 1rem 4rem; }

  /* Stats */
  .stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-bottom: 1.5rem; }
  .stat { background: var(--surface); border-radius: var(--radius); border: 0.5px solid var(--border); padding: 1rem 1.1rem; }
  .stat-label { font-size: 11px; color: var(--text3); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 5px; }
  .stat-value { font-size: 26px; font-weight: 600; color: var(--text); line-height: 1; }
  .stat-value.green { color: var(--green); }
  .stat-value.amber { color: var(--amber); }
  .stat-sub { font-size: 11px; color: var(--text3); margin-top: 3px; }

  /* Tabs */
  .tabs { display: flex; gap: 6px; margin-bottom: 1.1rem; }
  .tab { padding: 6px 16px; font-size: 13px; border-radius: 8px; border: 0.5px solid var(--border-md); background: transparent; color: var(--text2); cursor: pointer; transition: all 0.15s; font-family: inherit; font-weight: 500; }
  .tab.active { background: var(--text); color: #fff; border-color: var(--text); }
  .tab:hover:not(.active) { background: var(--surface2); }

  /* Search */
  .search-wrap { margin-bottom: 1.1rem; position: relative; }
  .search-wrap svg { position: absolute; left: 11px; top: 50%; transform: translateY(-50%); width: 15px; height: 15px; color: var(--text3); pointer-events: none; }
  .search-input { width: 100%; padding: 8px 12px 8px 34px; border: 0.5px solid var(--border-md); border-radius: var(--radius); background: var(--surface); font-size: 13px; color: var(--text); font-family: inherit; outline: none; transition: border-color 0.15s; }
  .search-input:focus { border-color: rgba(0,0,0,0.35); }
  .search-input::placeholder { color: var(--text3); }

  /* Cards */
  .tender-list { display: flex; flex-direction: column; gap: 8px; }
  .tender-card { background: var(--surface); border: 0.5px solid var(--border); border-radius: var(--radius-lg); overflow: hidden; transition: border-color 0.15s; }
  .tender-card:hover { border-color: var(--border-md); }
  .tender-card.expanded { border-color: rgba(0,0,0,0.30); }
  .card-header { padding: 1rem 1.2rem; cursor: pointer; display: flex; align-items: flex-start; gap: 12px; user-select: none; }
  .status-pill { display: inline-flex; align-items: center; gap: 4px; font-size: 11px; font-weight: 600; padding: 3px 10px; border-radius: 20px; white-space: nowrap; flex-shrink: 0; margin-top: 1px; }
  .pill-bid { background: var(--green-bg); color: var(--green); }
  .pill-pending { background: var(--amber-bg); color: var(--amber); }
  .pill-dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; }
  .card-info { flex: 1; min-width: 0; }
  .tender-id { font-size: 11px; color: var(--text3); font-family: 'Courier New', monospace; margin-bottom: 3px; }
  .tender-name { font-size: 14px; font-weight: 600; color: var(--text); line-height: 1.4; }
  .tender-client { font-size: 12px; color: var(--text2); margin-top: 3px; }
  .card-meta { text-align: right; flex-shrink: 0; }
  .amount { font-size: 15px; font-weight: 600; color: var(--text); }
  .amount-label { font-size: 11px; color: var(--text3); margin-top: 1px; }
  .open-date { font-size: 11px; color: var(--text3); margin-top: 4px; }
  .chevron { margin-top: 2px; flex-shrink: 0; transition: transform 0.2s; color: var(--text3); }
  .chevron.open { transform: rotate(180deg); }

  /* Expanded detail */
  .card-detail { display: none; border-top: 0.5px solid var(--border); padding: 1rem 1.2rem; }
  .card-detail.open { display: block; }
  .detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem 1.5rem; margin-bottom: 0.9rem; }
  .detail-item label { font-size: 10px; text-transform: uppercase; letter-spacing: 0.07em; color: var(--text3); display: block; margin-bottom: 3px; }
  .detail-item span { font-size: 13px; color: var(--text); }
  .section-title { font-size: 10px; text-transform: uppercase; letter-spacing: 0.07em; color: var(--text3); margin-bottom: 6px; }
  .response-box { background: var(--surface2); border-radius: 8px; padding: 10px 13px; font-size: 13px; color: var(--text); line-height: 1.7; border-left: 3px solid var(--green); margin-bottom: 0.75rem; }
  .response-box.amber { border-left-color: var(--amber); }
  .notes-box { font-size: 12px; color: var(--text2); line-height: 1.6; }

  /* Loading / empty */
  .state-msg { text-align: center; padding: 3.5rem 1rem; color: var(--text3); font-size: 14px; }
  .state-msg svg { display: block; margin: 0 auto 10px; width: 32px; height: 32px; opacity: 0.4; }

  /* Error banner */
  .error-banner { background: #fef2f2; border: 0.5px solid #fca5a5; border-radius: var(--radius); padding: 10px 14px; font-size: 13px; color: #991b1b; margin-bottom: 1rem; display: none; }
  .error-banner a { color: #991b1b; }

  /* Config modal */
  .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.4); display: none; align-items: center; justify-content: center; z-index: 200; }
  .modal-overlay.open { display: flex; }
  .modal { background: var(--surface); border-radius: var(--radius-lg); padding: 1.5rem; width: 90%; max-width: 480px; }
  .modal h2 { font-size: 16px; font-weight: 600; margin-bottom: 6px; }
  .modal p { font-size: 13px; color: var(--text2); margin-bottom: 1rem; line-height: 1.6; }
  .modal input { width: 100%; padding: 8px 12px; border: 0.5px solid var(--border-md); border-radius: 8px; font-size: 13px; font-family: monospace; outline: none; margin-bottom: 0.75rem; transition: border-color 0.15s; }
  .modal input:focus { border-color: rgba(0,0,0,0.4); }
  .modal-btns { display: flex; gap: 8px; justify-content: flex-end; }
  .btn-primary { background: var(--text); color: #fff; border: none; border-radius: 8px; padding: 7px 18px; font-size: 13px; font-family: inherit; cursor: pointer; }
  .btn-secondary { background: none; border: 0.5px solid var(--border-md); border-radius: 8px; padding: 7px 18px; font-size: 13px; font-family: inherit; cursor: pointer; color: var(--text2); }

  /* Spinner */
  @keyframes spin { to { transform: rotate(360deg); } }
  .spinner { width: 20px; height: 20px; border: 2px solid var(--border); border-top-color: var(--text2); border-radius: 50%; animation: spin 0.7s linear infinite; margin: 0 auto 10px; }
</style>
</head>
<body>

<div class="topbar">
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
  <span class="topbar-logo">陪標管理系統</span>
  <span class="topbar-sub" id="topbar-sub"></span>
  <div class="topbar-right">
    <span class="last-updated" id="last-updated"></span>
    <button class="refresh-btn" onclick="loadData()">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
      重新整理
    </button>
    <button class="refresh-btn" onclick="openConfig()">⚙ 設定</button>
  </div>
</div>

<div class="container">
  <div class="error-banner" id="error-banner"></div>
  <div class="stats" id="stats">
    <div class="stat"><div class="stat-label">總標案</div><div class="stat-value" id="s-total">—</div></div>
    <div class="stat"><div class="stat-label">已投標</div><div class="stat-value green" id="s-bid">—</div></div>
    <div class="stat"><div class="stat-label">未投標</div><div class="stat-value amber" id="s-pending">—</div></div>
  </div>

  <div class="tabs">
    <button class="tab active" onclick="setTab('all')" id="tab-all">全部</button>
    <button class="tab" onclick="setTab('pending')" id="tab-pending">未投標</button>
    <button class="tab" onclick="setTab('bid')" id="tab-bid">已投標</button>
  </div>

  <div class="search-wrap">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <input type="text" class="search-input" id="search" placeholder="搜尋標案號碼或名稱…" oninput="render()">
  </div>

  <div class="tender-list" id="list">
    <div class="state-msg"><div class="spinner"></div>載入資料中…</div>
  </div>
</div>

<!-- Config Modal -->
<div class="modal-overlay" id="modal">
  <div class="modal">
    <h2>🔧 設定 API 網址</h2>
    <p>請貼上您的 Google Apps Script 部署網址（Web App URL）。設定後會儲存在本機，下次開啟不需重新輸入。</p>
    <input type="text" id="api-url-input" placeholder="https://script.google.com/macros/s/xxxxx/exec">
    <div class="modal-btns">
      <button class="btn-secondary" onclick="closeConfig()">取消</button>
      <button class="btn-primary" onclick="saveConfig()">儲存並載入</button>
    </div>
  </div>
</div>

<script>
// ── 設定區 ──────────────────────────────
// 如果想把網址直接寫死，可填在這裡（留空則每次從 localStorage 讀取）
const HARDCODED_API_URL = 'https://script.google.com/macros/s/AKfycbyEkZJz_7XJlQjLURIrSmVQgxl43kbEQ9mWucSf3cHwxb0YHitzv1YKPPOVlVtiiGtt/exec';
// ────────────────────────────────────────

let allData = [];
let currentTab = 'all';

function getApiUrl() {
  return HARDCODED_API_URL || localStorage.getItem('tender_api_url') || '';
}

function openConfig() {
  document.getElementById('api-url-input').value = getApiUrl();
  document.getElementById('modal').classList.add('open');
}

function closeConfig() {
  document.getElementById('modal').classList.remove('open');
}

function saveConfig() {
  const url = document.getElementById('api-url-input').value.trim();
  if (!url) { alert('請輸入網址'); return; }
  localStorage.setItem('tender_api_url', url);
  closeConfig();
  loadData();
}

async function loadData() {
  const url = getApiUrl();
  if (!url) {
    openConfig();
    return;
  }

  document.getElementById('list').innerHTML = '<div class="state-msg"><div class="spinner"></div>載入中…</div>';
  document.getElementById('error-banner').style.display = 'none';

  try {
    const res = await fetch(url);
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    const json = await res.json();

    if (!Array.isArray(json)) throw new Error('回傳格式錯誤，請確認 Apps Script 程式碼');

    allData = json;
    updateStats();
    render();

    const now = new Date();
    document.getElementById('last-updated').textContent = `更新：${now.getHours().toString().padStart(2,'0')}:${now.getMinutes().toString().padStart(2,'0')}`;
    document.getElementById('topbar-sub').textContent = `共 ${allData.length} 筆`;
  } catch (e) {
    showError(`載入失敗：${e.message}。請確認 Apps Script 網址正確，且已設定「所有人可存取」。`);
    document.getElementById('list').innerHTML = '<div class="state-msg">⚠️ 無法載入資料</div>';
  }
}

function showError(msg) {
  const b = document.getElementById('error-banner');
  b.textContent = msg;
  b.style.display = 'block';
}

function updateStats() {
  const bid = allData.filter(t => t.status === '已投標').length;
  const pending = allData.filter(t => t.status === '未投標').length;
  document.getElementById('s-total').textContent = allData.length;
  document.getElementById('s-bid').textContent = bid;
  document.getElementById('s-pending').textContent = pending;
}

function setTab(tab) {
  currentTab = tab;
  ['all','pending','bid'].forEach(t => document.getElementById('tab-'+t).classList.toggle('active', t===tab));
  render();
}

function fmtAmount(n) {
  const num = parseInt((n+'').replace(/,/g,''));
  if (isNaN(num)) return n;
  return '$' + num.toLocaleString('zh-TW');
}

function render() {
  const q = document.getElementById('search').value.trim().toLowerCase();
  let data = allData;

  if (currentTab === 'pending') data = data.filter(t => t.status === '未投標');
  if (currentTab === 'bid') data = data.filter(t => t.status === '已投標');
  if (q) data = data.filter(t =>
    (t.id+'').toLowerCase().includes(q) ||
    (t.name+'').toLowerCase().includes(q) ||
    (t.client+'').toLowerCase().includes(q)
  );

  if (data.length === 0) {
    document.getElementById('list').innerHTML = '<div class="state-msg">沒有符合的標案</div>';
    return;
  }

  document.getElementById('list').innerHTML = data.map((t, i) => {
    const isBid = t.status === '已投標';
    return `
    <div class="tender-card" id="card-${i}">
      <div class="card-header" onclick="toggle(${i})">
        <span class="status-pill ${isBid ? 'pill-bid' : 'pill-pending'}">
          <span class="pill-dot"></span>${t.status}
        </span>
        <div class="card-info">
          <div class="tender-id">${t.id || '—'}</div>
          <div class="tender-name">${t.name || '（無名稱）'}</div>
          <div class="tender-client">${t.client || ''}</div>
        </div>
        <div class="card-meta">
          <div class="amount">${fmtAmount(t.amount)}</div>
          <div class="amount-label">陪標金額</div>
          ${t.open_date ? `<div class="open-date">開標 ${t.open_date}</div>` : ''}
        </div>
        <svg class="chevron" id="chev-${i}" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
      </div>
      <div class="card-detail" id="detail-${i}">
        <div class="detail-grid">
          <div class="detail-item"><label>客戶單位</label><span>${t.client || '—'}</span></div>
          <div class="detail-item"><label>開標日期</label><span>${t.open_date || '—'}</span></div>
          <div class="detail-item"><label>標案號碼</label><span style="font-family:monospace">${t.id || '—'}</span></div>
          <div class="detail-item"><label>陪標金額</label><span>${fmtAmount(t.amount)}</span></div>
        </div>
        <div class="section-title">應對話術</div>
        <div class="response-box ${isBid ? '' : 'amber'}">${(t.response || '（未填寫）').replace(/\n/g,'<br>')}</div>
        ${t.notes ? `<div class="section-title">備註</div><div class="notes-box">${t.notes.replace(/\n/g,'<br>')}</div>` : ''}
      </div>
    </div>`;
  }).join('');
}

function toggle(i) {
  const detail = document.getElementById('detail-'+i);
  const chev = document.getElementById('chev-'+i);
  const card = document.getElementById('card-'+i);
  const isOpen = detail.classList.contains('open');
  detail.classList.toggle('open', !isOpen);
  chev.classList.toggle('open', !isOpen);
  card.classList.toggle('expanded', !isOpen);
}

// Init
window.addEventListener('load', () => {
  if (!getApiUrl()) {
    document.getElementById('list').innerHTML = '<div class="state-msg">請先點右上角「⚙ 設定」輸入 API 網址</div>';
  } else {
    loadData();
  }
});
</script>
</body>
</html>
